# =============================================================================
# Ad Fontes Manager environment variable example
# Copy this file to `.env` in development and replace the placeholder values.
# =============================================================================

# -----------------------------------------------------------------------------
# 1. Core settings (required)
# -----------------------------------------------------------------------------

# Runtime environment: development | production | test
NODE_ENV=development

# Admin write token. Production requires a cryptographically random value
# with at least 32 characters. Example: openssl rand -hex 32
ADMIN_TOKEN=replace-with-a-secure-admin-token

# -----------------------------------------------------------------------------
# 2. Database settings (required)
# -----------------------------------------------------------------------------

# PostgreSQL connection string
DATABASE_URL=postgresql://postgres:password@localhost:5432/ad_fontes

# Enable SSL for PostgreSQL connections in production
DATABASE_SSL=false

# Optional connection pool size. If unset, the server uses environment defaults.
# DATABASE_POOL_SIZE=10

# -----------------------------------------------------------------------------
# 3. Server settings
# -----------------------------------------------------------------------------

# Backend API listen port
PORT=8080

# Legacy alias for PORT. Avoid setting both to different values.
# SERVER_PORT=8080

# Server bind host. Use 127.0.0.1 for local-only development, 0.0.0.0 for Docker.
SERVER_HOST=127.0.0.1

# Allowed CORS origins. Use a JSON array string. ["*"] allows all origins.
SERVER_CORS_ORIGINS=["http://localhost:5173"]

# Max requests per minute per client IP. Set 0 to disable rate limiting.
SERVER_RATE_LIMIT=0

# Request timeout in milliseconds. Set 0 to disable the timeout.
SERVER_TIMEOUT_MS=10000

# Helmet / security headers toggles
SECURITY_HELMET=true
SECURITY_HSTS=false

# -----------------------------------------------------------------------------
# 4. Client and local storage settings
# -----------------------------------------------------------------------------

# Vite development server port
CLIENT_DEV_PORT=5173

# Max number of unsynced local draft items stored on the backend side
MAX_LOCAL_ITEMS=100

# -----------------------------------------------------------------------------
# 5. Logging settings
# -----------------------------------------------------------------------------

# Log level: debug | info | warn | error
LOG_LEVEL=info

# Directory for rotating log files in production
LOG_DIR=./logs

# Rotating file stream options (production logger)
LOG_ROTATION_INTERVAL=1d
LOG_ROTATION_MAX_SIZE=10M
LOG_ROTATION_MAX_FILES=30

# -----------------------------------------------------------------------------
# 6. Environment-specific examples
# -----------------------------------------------------------------------------

# Development example
# NODE_ENV=development
# DATABASE_URL=postgresql://postgres:password@localhost:5432/ad_fontes_dev
# PORT=8080
# CLIENT_DEV_PORT=5173
# SECURITY_HSTS=false
# LOG_LEVEL=debug

# Production example
# NODE_ENV=production
# ADMIN_TOKEN=<openssl rand -hex 32>
# DATABASE_URL=postgresql://<user>:<pass>@<host>:5432/<db>?sslmode=require
# DATABASE_SSL=true
# SERVER_HOST=0.0.0.0
# SERVER_CORS_ORIGINS=["https://yourdomain.com"]
# SERVER_RATE_LIMIT=120
# SECURITY_HSTS=true
# LOG_LEVEL=warn
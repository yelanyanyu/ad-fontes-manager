# =============================================================================
# Ad Fontes Manager 环境变量配置示例
# 复制此文件为 .env 并根据需要修改
# =============================================================================

# -----------------------------------------------------------------------------
# 1. 核心配置 (必需)
# -----------------------------------------------------------------------------

# 运行环境: development | production | test
NODE_ENV=development

# 管理员 API 访问令牌（生产环境必须设置，32位以上随机字符串）
# 生成命令: openssl rand -hex 32
ADMIN_TOKEN=your-secure-admin-token-min-32-chars

# -----------------------------------------------------------------------------
# 2. 数据库配置 (必需)
# -----------------------------------------------------------------------------

# PostgreSQL 连接字符串
# 格式: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# 生产环境建议启用 SSL: postgresql://...?sslmode=require
DATABASE_URL=postgresql://postgres:password@localhost:5432/ad_fontes

# 强制使用 SSL 连接（生产环境必须设为 true）
DATABASE_SSL=false

# 连接池大小（可选，未设置时自动计算: dev=10, prod=20）
# DATABASE_POOL_SIZE=20

# -----------------------------------------------------------------------------
# 3. 服务器配置 (可选)
# -----------------------------------------------------------------------------

# API 服务器端口
# 优先级: PORT > SERVER_PORT
PORT=8080
SERVER_PORT=8080

# 服务器绑定地址
# - 0.0.0.0: 监听所有网络接口（Docker/生产环境）
# - 127.0.0.1: 仅本地访问（开发环境）
SERVER_HOST=0.0.0.0

# 允许的跨域来源（JSON 数组格式）
# 生产环境必须限制为实际域名，例如: ["https://yourdomain.com"]
SERVER_CORS_ORIGINS=["*"]

# 速率限制：每分钟最大请求数（0 表示禁用）
# 生产环境建议: 100-300
SERVER_RATE_LIMIT=0

# 请求超时（毫秒）
SERVER_TIMEOUT_MS=10000

# -----------------------------------------------------------------------------
# 4. 存储配置 (可选)
# -----------------------------------------------------------------------------

# 浏览器 LocalStorage 最大条目数
STORAGE_MAX_ITEMS=100

# -----------------------------------------------------------------------------
# 5. 日志配置 (可选)
# -----------------------------------------------------------------------------

# 日志级别: debug | info | warn | error
LOG_LEVEL=info

# 是否同时输出到文件: true | false
LOG_ENABLE_FILE=false

# 日志文件路径（启用文件日志时有效）
# LOG_FILE_PATH=./logs/app.log

# 是否启用安全审计日志: true | false
LOG_AUDIT=true

# -----------------------------------------------------------------------------
# 环境特定配置示例
# -----------------------------------------------------------------------------

# --- 开发环境 (.env.development) ---
# NODE_ENV=development
# ADMIN_TOKEN=dev-token-not-for-production
# DATABASE_URL=postgresql://postgres:password@localhost:5432/ad_fontes_dev
# SERVER_PORT=3000
# LOG_LEVEL=debug

# --- 生产环境 (.env.production) ---
# NODE_ENV=production
# ADMIN_TOKEN=<openssl rand -hex 32>
# DATABASE_URL=postgresql://<user>:<pass>@<host>:5432/<db>?sslmode=require
# SERVER_CORS_ORIGINS=["https://yourdomain.com"]
# SERVER_RATE_LIMIT=100
# DATABASE_SSL=true
# LOG_LEVEL=warn
# LOG_ENABLE_FILE=true

# --- 测试环境 (.env.test) ---
# NODE_ENV=test
# DATABASE_URL=postgresql://postgres:password@localhost:5432/ad_fontes_test
# LOG_LEVEL=error

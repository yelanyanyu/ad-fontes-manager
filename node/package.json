{
  "name": "ad-fontes-loader",
  "version": "1.0.0",
  "description": "YAML to SQLite loader for Ad Fontes Manager",
  "main": "loader.ts",
  "scripts": {
    "loader": "tsx loader.ts",
    "init-db": "tsx init_db.ts",
    "verify-sqlite-migration": "tsx verify-sqlite-migration.ts",
    "type-check": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write ."
  },
  "dependencies": {
    "better-sqlite3": "^12.9.0",
    "compromise": "^14.14.5",
    "deep-diff": "^1.0.2",
    "dotenv": "^16.3.1",
    "drizzle-orm": "^0.45.2",
    "js-yaml": "^4.1.0",
    "pg": "^8.11.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/deep-diff": "^1.0.5",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.3.3",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}

{
  "name": "ad-fontes-manager",
  "version": "1.0.0",
  "description": "Ad Fontes Manager web and desktop application",
  "license": "AGPL-3.0-only",
  "main": "out/main/index.js",
  "scripts": {
    "dev:web": "concurrently \"npm run dev:server\" \"npm run dev:renderer\"",
    "dev:server": "cross-env NODE_ENV=development tsx watch src/server/standalone.ts",
    "dev:renderer": "vite",
    "dev:desktop": "electron-vite dev",
    "build:web:renderer": "vite build",
    "build:web:server": "cross-env NODE_ENV=production tsc -p tsconfig.node.json --noEmit",
    "build:web": "npm run build:web:renderer",
    "build:desktop:server": "tsc -p tsconfig.server-build.json",
    "build:desktop:win": "electron-vite build && npm run build:desktop:server && npm run rebuild:electron:native && electron-builder --win && npm run restore:native-after-desktop-build",
    "build:desktop:mac": "electron-vite build && npm run build:desktop:server && npm run rebuild:electron:native && electron-builder --mac && npm run restore:native-after-desktop-build",
    "rebuild:electron:native": "node scripts/rebuild-electron-native.mjs",
    "rebuild:node:native": "npm rebuild better-sqlite3",
    "restore:native-after-desktop-build": "node scripts/restore-native-after-desktop-build.mjs",
    "start:web": "cross-env NODE_ENV=production tsx src/server/standalone.ts",
    "type-check": "vue-tsc --noEmit -p tsconfig.json && tsc -p tsconfig.node.json --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "test-api": "tsx src/server/test-api.ts",
    "db:init": "tsx node/init_db.ts",
    "db:import": "tsx node/loader.ts",
    "db:view": "tsx node/view-word-yaml.ts",
    "db:diff": "tsx node/check-word-diff.ts",
    "format": "prettier --write ."
  },
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  },
  "dependencies": {
    "@fortawesome/fontawesome-free": "^7.1.0",
    "anki-apkg-export": "^4.0.3",
    "axios": "^1.13.3",
    "better-sqlite3": "^12.9.0",
    "bottleneck": "^2.19.5",
    "compromise": "^14.14.5",
    "consola": "^3.4.2",
    "cors": "^2.8.5",
    "deep-diff": "^1.0.2",
    "dotenv": "^16.6.1",
    "drizzle-orm": "^0.45.2",
    "express": "^5.0.0",
    "github-markdown-css": "^5.8.1",
    "helmet": "^8.1.0",
    "html-to-image": "^1.11.13",
    "http-errors": "^2.0.1",
    "http-status-codes": "^2.3.0",
    "js-yaml": "^4.1.1",
    "marked": "^17.0.1",
    "pinia": "^3.0.4",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "rotating-file-stream": "^3.2.9",
    "vue": "^3.5.24",
    "vue-router": "^4.6.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.1",
    "@eslint/js": "^9.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.3.3",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "@vitejs/plugin-vue": "^6.0.1",
    "autoprefixer": "^10.4.23",
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "drizzle-kit": "^0.31.10",
    "electron": "^39.2.7",
    "electron-builder": "^26.0.12",
    "electron-vite": "^4.0.1",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-vue": "^10.8.0",
    "postcss": "^8.5.6",
    "prettier": "^3.8.1",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^7.2.4",
    "vitest": "^2.1.9",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "^3.2.5"
  }
}
